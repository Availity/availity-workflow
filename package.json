{
  "private": true,
  "name": "availity-workflow",
  "type": "module",
  "engines": {
    "yarn": "^4.0.0",
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "docusaurus",
    "example",
    "vite-example"
  ],
  "scripts": {
    "build": "yarn nx run-many --target=build",
    "build:app": "yarn workspace @availity/example build",
    "build:vite-app": "yarn workspace @availity/vite-example build",
    "build:docs": "yarn workspace @availity/dinosaurdocs build",
    "check:packages": "sh ./scripts/artifactory-check.sh",
    "format": "prettier --write 'packages/*/*.(js|ts|tsx|jsx)' 'packages/*/!(node_modules|dist)/**/*.(js|ts|jsx|tsx)'",
    "lint": "nx affected --target=lint",
    "lint:all": "nx run-many --target=lint",
    "lint:fix": "nx affected --target=lint --fix",
    "postinstall": "is-ci || husky",
    "prepare": "husky",
    "start": "yarn workspace @availity/dinosaurdocs start --no-open",
    "start:app": "yarn workspace @availity/example start",
    "start:vite-app": "yarn workspace @availity/vite-example start",
    "start:docs": "yarn workspace @availity/dinosaurdocs start",
    "test": "vitest run",
    "test:affected": "nx affected --target=test",
    "test:app": "yarn workspace @availity/example test",
    "test:vite-app": "yarn workspace @availity/vite-example test",
    "test:integration": "yarn workspaces foreach -i -v run integration --verbose",
    "version": "nx affected --target version --parallel=1",
    "version:dry-run": "nx affected --target version --dryRun --verbose --parallel=1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/config-nx-scopes": "^21.0.2",
    "@jscutlery/semver": "^5.8.1",
    "@nx/js": "22.5.1",
    "@nx/workspace": "22.5.1",
    "eslint-config-availity": "^14.0.0",
    "gh-pages": "^5.0.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.7",
    "nx": "22.5.1",
    "prettier": "^3.8.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "yarn@4.12.0"
}
