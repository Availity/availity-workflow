{
  "name": "vite-example",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "./vite-example"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "av test",
        "cwd": "vite-example"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cross-env NODE_ENV=production av build",
        "cwd": "vite-example"
      }
    }
  }
}
