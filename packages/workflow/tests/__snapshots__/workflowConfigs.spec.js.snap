                      },
                      {
                        "postcssPlugin": "postcss-progressive-custom-properties",
                      },
                      {
                        "options": {
                          "flexbox": "no-2009",
                        },
                        "postcssPlugin": "autoprefixer",
                      },
                      {
                        "postcssPlugin": "postcss-preset-env",
                      },
                    ],
                    "postcssPlugin": "postcss-preset-env",
                  },
                  {
                    "postcssPlugin": "postcss-reporter",
                  },
                ],
              },
              "sourceMap": true,
            },
          },
        ],
      },
      {
        "test": {},
        "use": [
          "style-loader",
          {
            "loader": "css-loader",
            "options": {
              "sourceMap": true,
            },
          },
          {
            "loader": "postcss-loader",
