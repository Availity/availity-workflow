      "version": 5,
    },
    {
      "options": {
        "contextRegExp": {},
        "resourceRegExp": {},
      },
    },
    {
      "fsOperations": 0,
      "logger": {},
      "options": {},
      "pathCache": {},
      "primed": false,
    },
    {
      "options": {
        "emitError": false,
        "showHelp": true,
        "strict": true,
        "verbose": true,
      },
    },
    {
      "key": "ESLintWebpackPlugin",
      "options": {
        "cache": true,
        "cacheLocation": "<ROOT>/node_modules/.cache/.eslintcache",
        "emitError": true,
        "emitWarning": true,
        "extensions": [
          "js",
          "jsx",
          "ts",
          "tsx",
          "mjs",
        ],
        "failOnError": true,
        "resourceQueryExclude": [],
      },
    },
    {
      "options": {
        "exclude": {},
        "include": {},
        "overlay": {
          "entry": "<ROOT>/node_modules/@pmmmwh/react-refresh-webpack-plugin/client/ErrorOverlayEntry.js",
          "module": "<ROOT>/node_modules/@pmmmwh/react-refresh-webpack-plugin/overlay/index.js",
          "sockIntegration": "wds",
        },
      },
    },
    {
      "isFirstBuild": true,
      "lastBuildSucceeded": false,
      "options": {
        "contentImage": "<ROOT>/packages/workflow/public/availity.png",
        "excludeWarnings": true,
      },
    },
  ],
  "resolve": {
    "extensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".json",
      ".css",
      ".scss",
    ],
    "fallback": {
      "path": "<ROOT>/node_modules/path-browserify/index.js",
    },
    "modules": [
      "<ROOT>/project/app",
      "node_modules",
      "<ROOT>/node_modules",
      "<ROOT>/packages/workflow/node_modules",
    ],
    "plugins": [
      {
        "absoluteBaseUrl": "<ROOT>/example",
        "baseUrl": "./example/",
        "extensions": [
          ".js",
          ".jsx",
          ".ts",
          ".tsx",
        ],
        "log": {},
        "referenceMatchMap": {},
        "source": "described-resolve",
        "target": "resolve",
      },
    ],
    "symlinks": true,
  },
  "resolveLoader": {
    "modules": [
      "<ROOT>/node_modules",
      "<ROOT>/packages/workflow/node_modules",
    ],
    "symlinks": true,
  },
  "stats": "minimal",
  "target": "browserslist: last 1 chrome version, last 1 firefox version, last 1 safari version",
}
