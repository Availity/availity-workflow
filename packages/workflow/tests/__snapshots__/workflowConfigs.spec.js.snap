"{
  "context": "<PROJECT_ROOT>/project/app",
  "experiments": {},
  "infrastructureLogging": {
    "level": "warn"
  },
  "entry": {
    "index": [
      "<PROJECT_ROOT>/node_modules/react-app-polyfill/stable.js",
      "<PROJECT_ROOT>/node_modules/navigator.sendbeacon/dist/navigator.sendbeacon.cjs.js",
      "<PROJECT_ROOT>/project/app/index.js"
    ]
  },
  "output": {
    "path": "<PROJECT_ROOT>/build",
    "filename": "[name].js",
    "chunkFilename": "[name].chunk.js"
  },
  "devtool": "source-map",
  "resolve": {
    "modules": [
      "<PROJECT_ROOT>/project/app",
      "node_modules",
      "<PROJECT_ROOT>/node_modules",
      "<PROJECT_ROOT>/packages/workflow/node_modules"
    ],
    "symlinks": true,
    "extensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".json",
      ".css",
      ".scss"
    ],
    "fallback": {
      "path": "<PROJECT_ROOT>/node_modules/path-browserify/index.js"
    },
    "plugins": [
      {
        "source": "described-resolve",
        "target": "resolve",
        "extensions": [
          ".js",
          ".jsx",
          ".ts",
          ".tsx"
        ],
        "referenceMatchMap": {},
        "log": {},
        "baseUrl": "./example/",
        "absoluteBaseUrl": "<PROJECT_ROOT>/example"
      }
    ]
  },
  "resolveLoader": {
    "modules": [
      "<PROJECT_ROOT>/node_modules",
      "<PROJECT_ROOT>/packages/workflow/node_modules"
    ],
    "symlinks": true
  },
  "plugins": [
    {
      "definitions": {
        "__DEV__": false,
        "__TEST__": true,
        "__PROD__": false,
        "__STAGING__": false,
        "process.env.NODE_ENV": "\\"test\\""
      }
    },
    {
      "options": {
        "banner": "APP_VERSION=\\"N/A\\";",
        "test": {},
        "raw": true,
        "entryOnly": true
      }
    },
    {
      "options": {
        "banner": "vN/A - 2023-03-28T16:07:07.909Z"
      }
    },
    {
      "userOptions": {
        "template": "../../packages/workflow/public/index.html",
        "favicon": "../../packages/workflow/public/favicon.ico",
        "title": "Availity"
      },
      "version": 5,
      "options": {
        "template": "../../packages/workflow/public/index.html",
        "templateContent": false,
        "filename": "index.html",
        "publicPath": "auto",
        "hash": false,
        "inject": "head",
        "scriptLoading": "defer",
        "compile": true,
        "favicon": "../../packages/workflow/public/favicon.ico",
        "minify": "auto",
        "cache": true,
        "showErrors": true,
        "chunks": "all",
        "excludeChunks": [],
        "chunksSortMode": "auto",
        "meta": {},
        "base": false,
        "title": "Availity",
        "xhtml": false
      }
    },
    {
      "options": {
        "resourceRegExp": {},
        "contextRegExp": {}
      }
    },
    {
      "options": {},
      "logger": {},
      "pathCache": {},
      "fsOperations": 0,
      "primed": false
    },
    {
      "options": {
        "verbose": true,
        "showHelp": true,
        "emitError": false,
        "strict": true
      }
    },
    {
      "key": "ESLintWebpackPlugin",
      "options": {
        "cache": true,
        "cacheLocation": "<PROJECT_ROOT>/node_modules/.cache/.eslintcache",
        "extensions": [
          "js",
          "jsx",
          "ts",
          "tsx",
          "mjs"
        ],
        "emitError": true,
        "emitWarning": true,
        "failOnError": true,
        "resourceQueryExclude": []
      }
    },
    {
      "options": {
        "exclude": {},
        "include": {},
        "overlay": {
          "entry": "<PROJECT_ROOT>/node_modules/@pmmmwh/react-refresh-webpack-plugin/client/ErrorOverlayEntry.js",
          "module": "<PROJECT_ROOT>/node_modules/@pmmmwh/react-refresh-webpack-plugin/overlay/index.js",
          "sockIntegration": "wds"
        }
      }
    },
    {
      "options": {
        "contentImage": "<PROJECT_ROOT>/packages/workflow/public/availity.png",
        "excludeWarnings": true
      },
      "lastBuildSucceeded": false,
      "isFirstBuild": true
    }
  ],
  "mode": "development",
  "target": "browserslist: last 1 chrome version, last 1 firefox version, last 1 safari version",
  "stats": "minimal",
  "module": {
    "rules": [
      {
        "test": {},
        "use": [
          {
            "loader": "imports-loader",
            "options": {
              "type": "commonjs",
              "imports": [
                "single process/browser process"
              ]
            }
          }
        ]
      },
      {
        "test": {},
        "include": [
          "<PROJECT_ROOT>/project/app",
          {}
        ],
        "use": [
          {
            "loader": "esbuild-loader",
            "options": {
              "loader": "tsx",
              "target": "es2015"
            }
          }
        ]
      },
      {
        "test": {},
        "resolve": {
          "fullySpecified": false
        }
      },
      {
        "test": {},
        "use": [
          "style-loader",
          {
            "loader": "css-loader",
            "options": {
              "sourceMap": true,
              "importLoaders": 1
            }
          },
          {
            "loader": "postcss-loader",
            "options": {
              "sourceMap": true,
              "postcssOptions": {
                "plugins": [
                  {
                    "postcssPlugin": "postcss-focus"
                  },
                  {
