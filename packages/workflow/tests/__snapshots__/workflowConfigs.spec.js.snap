        "chunksSortMode": "auto",
        "compile": true,
        "excludeChunks": [],
        "favicon": "../../packages/workflow/public/favicon.ico",
        "filename": "index.html",
        "hash": false,
        "inject": "head",
        "meta": {},
        "minify": "auto",
        "publicPath": "auto",
        "scriptLoading": "defer",
        "showErrors": true,
        "template": "../../packages/workflow/public/index.html",
        "templateContent": false,
        "title": "Availity",
        "xhtml": false,
