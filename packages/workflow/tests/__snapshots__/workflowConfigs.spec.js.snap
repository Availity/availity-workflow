      },
      {
        "generator": {
          "filename": "fonts/[name].[ext]",
        },
        "test": {},
        "type": "asset/resource",
      },
      {
        "generator": {
          "filename": "images/[name].[ext]",
        },
        "test": {},
        "type": "asset/resource",
      },
    ],
  },
  "output": {
