{
  "name": "@availity/workflow",
  "version": "13.0.3",
  "description": "Upgradable workflow for Availity boilerplate projects",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": "./index.js",
    "./vitest.config.js": "./vitest.config.js",
    "./webpack.config.js": "./webpack.config.js",
    "./webpack.config.production.js": "./webpack.config.production.js",
    "./settings": "./settings/index.js"
  },
  "bin": {
    "av": "./index.js",
    "workflow": "./index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Availity/availity-workflow.git"
  },
  "keywords": [
    "boilerplate",
    "workflow",
    "availity",
    "react"
  ],
  "author": "Robert McGuinness",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/availity/availity-workflow/issues"
  },
  "homepage": "https://github.com/availity/availity-workflow#readme",
  "scripts": {
    "generateChangelog": "yarn changelog:generate --tag-prefix $npm_package_name --lerna-package $npm_package_name",
    "generateTag": "yarn exec git tag --message \"${npm_package_name}@${npm_package_version}\" --annotate \"${npm_package_name}@${npm_package_version}\"",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "publish:canary": "yarn npm publish --access public --tag canary"
  },
  "dependencies": {
    "@availity/mock-server": "workspace:*",
    "@availity/workflow-logger": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.9",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "chalk": "^5.6.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "debug": "^4.4.3",
    "duplicate-package-checker-webpack-plugin": "^3.0.0",
    "envinfo": "^7.21.0",
    "esbuild-loader": "^4.5.0",
    "eslint-webpack-plugin": "^6.0.0",
    "get-port": "^7.2.0",
    "hosted-git-info": "^9.0.3",
    "html-webpack-plugin": "^5.6.7",
    "imports-loader": "^5.0.0",
    "joi": "^18.2.1",
    "jsdom": "^29.1.1",
    "mini-css-extract-plugin": "^2.10.2",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.15",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-focus": "^7.0.0",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.1",
    "postcss-reporter": "^7.1.0",
    "process": "^0.11.10",
    "react-refresh": "^0.18.0",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "semver": "^7.8.4",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "validate-npm-package-name": "^7.0.2",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-bundle-size-analyzer": "^3.1.0",
    "webpack-dev-server": "^5.2.5",
    "webpack-notifier": "^1.15.0",
    "yargs": "^18.0.0"
  },
  "peerDependencies": {
    "eslint-config-availity": ">=13.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
