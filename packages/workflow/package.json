{
  "name": "@availity/workflow",
  "version": "12.2.5",
  "description": "Upgradable workflow for Availity boilerplate projects",
  "type": "module",
  "main": "index.js",
  "bin": {
    "av": "./index.js",
    "workflow": "./index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Availity/availity-workflow.git"
